  <components>
    <!-- ==================== Core Runtime ==================== -->
    <component Cclass="Machine Learning" Cgroup="ExecuTorch" Csub="Runtime" Cversion="1.1.0-rc1-build.12" condition="Cortex-M">
      <description>ExecuTorch Core Runtime - Required for all ExecuTorch applications</description>
      <RTE_Components_h>
        #define RTE_ML_EXECUTORCH_RUNTIME     /* ExecuTorch Runtime */
      </RTE_Components_h>
      <Pre_Include_Global_h>
        /* ExecuTorch global configuration */
        #define C10_USING_CUSTOM_GENERATED_MACROS
        #define FLATBUFFERS_MAX_ALIGNMENT 1024
        #define FLATBUFFERS_LOCALE_INDEPENDENT 0
      </Pre_Include_Global_h>
      <files>
        <file category="sourceCpp" name="src/runtime/backend/interface.cpp"/>
        <file category="sourceCpp" name="src/runtime/core/evalue.cpp"/>
        <file category="sourceCpp" name="src/runtime/core/exec_aten/util/tensor_shape_to_c_string.cpp"/>
